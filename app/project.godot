; PM98 — native Android clone (Godot 4). Engine + 2D UI in one project.
; Match-highlights (Actua Soccer 2 3D + Barry Davies) are a later phase.

config_version=5

[application]

config/name="PM98"
config/description="Premier Manager 98 — native clone (personal project)"
run/main_scene="res://scenes/Main.tscn"
config/features=PackedStringArray("4.6", "GL Compatibility")
config/icon="res://icon.svg"

[autoload]

GameDB="*res://scripts/GameDB.gd"
AudioManager="*res://scripts/AudioManager.gd"

[display]

; Native PM98 resolution (640x480, 4:3). stretch "keep" letterboxes the whole game
; uniformly to any device with dark margins -- the full screen is ALWAYS shown,
; nothing is ever cropped or distorted (faithful to the PC game in a window).
window/size/viewport_width=640
window/size/viewport_height=480
window/handheld/orientation=0
window/stretch/mode="canvas_items"
window/stretch/aspect="keep"

[rendering]

renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
textures/vram_compression/import_etc2_astc=true
; Dark letterbox margins around the 4:3 game area.
environment/defaults/default_clear_color=Color(0.04, 0.05, 0.08, 1)
