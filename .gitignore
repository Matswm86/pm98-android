*.pyc
*.pyo
.DS_Store
.re-venv/

# ── Ghidra RE: project lives OUTSIDE the repo (~/ghidra-projects/pm98, ~45MB).
# The decompiled C dumps (docs/re/{decompiled,sim,flow}/*.c) + tooling (tools/re/)
# + findings (docs/re/*.md) ARE committed as the saved analysis for next session.

# ── Ghidra PCode-emulator transient run files (oracle TABLE + specs are kept)
tools/re/specs/_gate_run.*
tools/re/specs/_tree_run.*
tools/re/specs/_lut_zero.*
tools/re/specs/_lut_seed.*
tools/re/specs/rng.out

# ── Godot engine cache + generated import files (regenerated by CI on --import)
app/.godot/
**/*.import
*.translation
*.uid

# ── Android build artifacts (Gradle template installed in CI from export templates)
*.apk
*.aab
app/android/
app/export.log
app/shots/

